[user]
  name = {{name}}
  email = {{email}}
  signingkey = {{sshKey}}.pub
[core]
  ignorecase = false
  autocrlf = input
  excludesfile = ~/.gitignore
{{#if dotter.windows}}
  untrackedCache = true
  fsmonitor = true
  sshCommand = 'C:/Program Files/OpenSSH/ssh.exe'
  editor = code --wait
[http]
  sslBackend = schannel
{{/if}}
[column]
  ui = auto
[gpg]
  format = ssh
[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renames = true
  tool = vscode
[difftool "vscode"]
  cmd = code --wait --diff $LOCAL $REMOTE
[merge]
  tool = vscode
[mergetool "vscode"]
  cmd = code --wait --merge $REMOTE $LOCAL $BASE $MERGED
[difftool]
  prompt = false
[mergetool]
  trustExitCode = true
[protocol]
  version = 2
[init]
  defaultBranch = main
[commit]
  verbose = true
  gpgsign = true
[fetch]
  prune = true
  pruneTags = true
  all = false
[pull]
  ff = only
  rebase = true
[push]
  default = simple
  autoSetupRemote = true
  followTags = true
[checkout]
  defaultRemote = origin
[merge]
  ff = only
[rebase]
  autoSquash = true
  autoStash = true
  updateRefs = true
[rerere]
  enabled = true
  autoupdate = true
[branch]
  sort = -committerdate
[tag]
  sort = version:refname
[help]
  autocorrect = prompt
[alias]
  st = status -sb
  ll = log --oneline
  last = log -1 HEAD --stat
  hist = log --graph --abbrev-commit --decorate --date=short \
    --format=format:'%C(bold cyan)%h%C(reset) %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)%an%C(reset) %C(bold yellow)%d%C(reset)' \
    --branches --remotes --tags
{{#each workCodeDirs}}
[includeIf "gitdir:{{this}}"]
  path = ~/.gitconfigwork
{{/each}}
